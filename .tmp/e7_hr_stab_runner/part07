gs)
    phase_work = WORK_ROOT / phase
    args = [
        "plan",
        "--contract",
        CONTRACT,
        "--run-spec",
        RUN_SPEC,
        "--grid",
        GRID,
        "--work-dir",
        str(phase_work),
        "--max-workers",
        MAX_WORKERS,
    ]
    suite.main(args)
    if command == "plan":
        return
    os.environ[FULL_RUN_ENV] = "1"
    args[0] = "run"
    args.append("--resume")
    suite.main(args)


