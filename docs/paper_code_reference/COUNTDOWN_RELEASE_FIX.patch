diff --git a/paper_code/tests/test_common.py b/paper_code/tests/test_common.py
index 7f4c0dc..04efdcc 100644
--- a/paper_code/tests/test_common.py
+++ b/paper_code/tests/test_common.py
@@ -830,3 +830,105 @@ def test_countdown_structure_metrics_match_registered_pattern_semantics() -> Non
     assert metrics["greedy_heldout_pattern_precision_micro"] == pytest.approx(1.0)
     assert metrics["sampled_heldout_pattern_precision_micro"] == pytest.approx(1.0)
     assert metrics["greedy_unseen_structure_success"] == pytest.approx(1.0)
+
+
+def test_countdown_runtime_releases_model_before_loading_next(
+    monkeypatch: pytest.MonkeyPatch,
+    tmp_path: Path,
+) -> None:
+    import weakref
+
+    from drpo_reference.experiments import countdown as runtime
+
+    config_path = tmp_path / "config.json"
+    replay_path = tmp_path / "replay.jsonl"
+    calibration_path = tmp_path / "calibration.jsonl"
+    validation_path = tmp_path / "validation.jsonl"
+    for path in (config_path, replay_path, calibration_path, validation_path):
+        path.write_text("{}\n", encoding="utf-8")
+
+    class FakeConfig:
+        protocol_id = "custom-reviewer-coordinate"
+        model_path = "fake-model"
+        test_path = None
+        structure_reference_path = None
+        expected_replay_rows = None
+        expected_calibration_rows = None
+        expected_validation_rows = None
+        expected_test_rows = None
+        expected_structure_reference_rows = None
+        require_structure_metrics = False
+        max_length = 64
+        methods = ("positive_only", "exponential")
+        seeds = (7,)
+
+        def __init__(self) -> None:
+            self.replay_path = replay_path
+            self.calibration_path = calibration_path
+            self.validation_path = validation_path
+
+        def as_manifest(self) -> dict[str, object]:
+            return {"schema_version": 1}
+
+    class CyclicModel:
+        def __init__(self) -> None:
+            self.cycle = self
+
+    model_refs: list[weakref.ReferenceType[CyclicModel]] = []
+
+    def load_model(*args: object, **kwargs: object) -> CyclicModel:
+        del args, kwargs
+        if model_refs:
+            assert model_refs[-1]() is None
+        model = CyclicModel()
+        model_refs.append(weakref.ref(model))
+        return model
+
+    rows = {
+        replay_path: [{"prompt": "replay", "positive": "1", "negative_bank": ["2"]}],
+        calibration_path: [
+            {"prompt": "calibration", "positive": "1", "negative_bank": ["2"]}
+        ],
+        validation_path: [{"prompt": "validation", "numbers": [1], "target": 1}],
+    }
+
+    monkeypatch.setattr(runtime, "load_countdown_config", lambda path: FakeConfig())
+    monkeypatch.setattr(runtime, "_load_hf_stack", lambda: object())
+    monkeypatch.setattr(runtime, "_validate_model_identity", lambda config: {})
+    monkeypatch.setattr(runtime, "_adapter_identity", lambda config: {})
+    monkeypatch.setattr(runtime, "_read_jsonl", lambda path: rows[path])
+    monkeypatch.setattr(runtime, "_validate_training_rows", lambda *args: None)
+    monkeypatch.setattr(runtime, "_validate_evaluation_rows", lambda *args: None)
+    monkeypatch.setattr(runtime, "_load_tokenizer", lambda *args: SimpleNamespace(pad_token_id=0))
+    monkeypatch.setattr(runtime, "_prepare_training_items", lambda *args: ([], []))
+    monkeypatch.setattr(runtime, "_load_trainable_model", load_model)
+    monkeypatch.setattr(
+        runtime,
+        "_calibrate_for_seed",
+        lambda *args, **kwargs: {
+            "method_coefficients": {"positive_only": 0.0, "exponential": 1.0},
+            "shared_negative_scale": 1.0,
+            "tau": 1.0,
+            "surprisal_scale": 1.0,
+            "initial_trainable_state_sha256": "fake",
+        },
+    )
+
+    def train_method(*args: object, **kwargs: object) -> dict[str, object]:
+        del args
+        output = Path(kwargs["output"])
+        output.mkdir(parents=True, exist_ok=False)
+        return {
+            "method": kwargs["method"],
+            "seed": kwargs["seed"],
+            "status": "completed",
+        }
+
+    monkeypatch.setattr(runtime, "_train_one_method", train_method)
+    monkeypatch.setattr(runtime.torch.cuda, "is_available", lambda: False)
+
+    result = runtime.run_countdown(config_path=config_path, output_root=tmp_path / "output")
+
+    assert result["completion"]["completed_runs"] == 2
+    assert len(model_refs) == 3
+    assert all(reference() is None for reference in model_refs)
