{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:runtime-resource-policy:schema:v1",
  "$comment": "JSON Schema default values are annotations only. The production parser must materialize canonical defaults before identity construction.",
  "title": "Runtime Resource Policy V1",
  "description": "Project-neutral preflight resource-policy contract. Workload-specific parameters are validated by the resolved adapter.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mode"
  ],
  "dependentRequired": {
    "adapter_version": [
      "adapter"
    ]
  },
  "properties": {
    "schema_version": {
      "const": 1
    },
    "mode": {
      "enum": [
        "auto",
        "fixed",
        "exempt"
      ]
    },
    "adapter": {
      "type": "string",
      "minLength": 3,
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9_.-]*$",
      "description": "Caller-resolved adapter identifier. Required for auto and fixed modes."
    },
    "adapter_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "Optional requested exact adapter-version pin. The resolved exact version is always recorded in the selection artifact."
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "description": "Adapter-owned policy profile and parameters. When omitted, the production parser materializes the canonical conservative/empty value before identity construction.",
      "properties": {
        "profile": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "default": "conservative"
        },
        "parameters": {
          "type": "object",
          "default": {}
        }
      },
      "default": {
        "profile": "conservative",
        "parameters": {}
      }
    },
    "fixed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request"
      ],
      "properties": {
        "request": {
          "type": "object",
          "minProperties": 1,
          "description": "Opaque adapter-owned fixed resource request. The adapter must validate current safety before selection is frozen."
        }
      }
    },
    "exempt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason"
      ],
      "properties": {
        "reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "classification": {
          "enum": [
            "small_task",
            "no_parallelism",
            "external_scheduler",
            "other"
          ],
          "default": "other"
        },
        "details": {
          "type": "object",
          "default": {}
        }
      }
    }
  },
  "oneOf": [
    {
      "title": "Automatic selection",
      "properties": {
        "mode": {
          "const": "auto"
        }
      },
      "required": [
        "adapter"
      ],
      "not": {
        "anyOf": [
          {
            "required": [
              "fixed"
            ]
          },
          {
            "required": [
              "exempt"
            ]
          }
        ]
      }
    },
    {
      "title": "Validated fixed selection",
      "properties": {
        "mode": {
          "const": "fixed"
        }
      },
      "required": [
        "adapter",
        "fixed"
      ],
      "not": {
        "required": [
          "exempt"
        ]
      }
    },
    {
      "title": "Explicit exemption",
      "properties": {
        "mode": {
          "const": "exempt"
        }
      },
      "required": [
        "exempt"
      ],
      "not": {
        "anyOf": [
          {
            "required": [
              "adapter"
            ]
          },
          {
            "required": [
              "adapter_version"
            ]
          },
          {
            "required": [
              "policy"
            ]
          },
          {
            "required": [
              "fixed"
            ]
          }
        ]
      }
    }
  ]
}