digraph stage4_semantic_graph {
  graph [label="graph_hash=050a7a03b0566e231ad85dae29a4e4d57404d3ce988cfaa19d3b49e82ae98eea", labelloc="t"];
  rankdir=LR;
  node [shape=box];
  "claim:GOV-COLLAPSE-TAXONOMY-01" [label="claim: Task-performance collapse, support or variance boundary events, and NaN/Inf numerical failure must be reported separately."];
  "claim:GOV-CU1-TERMINOLOGY-01" [label="claim: Current C-U1 results are same-distribution held-out-context generalization, not OOD generalization."];
  "claim:GOV-CURRENT-ROUTE-E7-01" [label="claim: The current next formal route item is EXT-H-E7-Q2 and it remains not run until canonical execution and delivery complete."];
  "claim:GOV-DOCUMENT-FIRST-01" [label="claim: Formal experiments require prior registration of claim, environment, data, metrics, convergence criteria, and result destination."];
  "claim:GOV-E4-TAPER-FOLLOWUP-ORDER-01" [label="claim: The four approved E4-TAPER follow-ups remain blocked and must execute in the frozen order: near-retention matching, budget matching, long-run terminal resolution, then untouched-seed confirmation."];
  "claim:GOV-EXTERNAL-DOES-NOT-REPLACE-01" [label="claim: Hopper and Countdown provide external validity and do not replace C-U1/D-U1 controlled identification."];
  "claim:GOV-NONDESTRUCTIVE-HISTORY-01" [label="claim: Historical content may be moved or indexed but not destructively deleted."];
  "claim:GOV-TERMINAL-AUDIT-01" [label="claim: Steady-state, collapse, and method-ranking claims require terminal-state auditing rather than arbitrary fixed horizons."];
  "claim:GOV-UNIQUE-MASTER-01" [label="claim: docs/handoff.md is the unique research master and new research state must be registered there first."];
  "claim:HIST-HARD-FILTER-UNIQUE-01" [label="claim: The old paper narrative treated hard filtering as the necessary and unique solution."];
  "claim:HIST-MU-SIGMA-EXPAND-01" [label="claim: The old interpretation claimed that both Gaussian mean and variance expanded under far-field negative updates."];
  "claim:SCI-CATEGORICAL-BOUNDED-SCORE-01" [label="claim: Direct softmax logit score is bounded as token probability approaches zero, while repeated negatives still cause persistent support suppression."];
  "claim:SCI-COUNTDOWN-NOT-RUN-01" [label="open_issue: Countdown still lacks a complete real Qwen/CUDA/BF16-LoRA end-to-end run for the current protocol."];
  "claim:SCI-COUNTDOWN-ROLE-01" [label="claim: EXT-C/Countdown provides token-level discrete external validation rather than replacing D-U1."];
  "claim:SCI-CU1-E1-SOURCE-01" [label="claim: C-U1 E1 identifies far-field score geometry as an independent source of larger negative gradients at matched advantage."];
  "claim:SCI-CU1-E3-CAUSAL-01" [label="claim: C-U1 E3 long-run evidence supports far-field negative gradients as the causal path to task collapse and support contraction."];
  "claim:SCI-CU1-E4-TERMINAL-01" [label="limitation: C-U1 E4 supports finite-horizon phase-transition and failure branches but not a fully certified stable beneficial fixed point."];
  "claim:SCI-DU1-E5-BOUNDARY-01" [label="claim: D-U1 E5 long-run evidence validates bounded-score repeated repulsion and categorical support-boundary dynamics."];
  "claim:SCI-DU1-E6-GENERALIZATION-01" [label="claim: D-U1 E6 validates a non-monotonic benefit of controlled local negative signals and a semantic-alignment exclusion control."];
  "claim:SCI-E4-TAPER-INFLUENCE-TAIL-01" [label="claim: Under bounded-advantage, pre-boundary learnable-log-scale assumptions, reciprocal-quadratic weighting bounds the quadratic far-field influence at a generally nonzero constant, while o(d^-2) tails such as higher-order reciprocal polynomials or exponentials make that influence vanish; this does not imply a universal reward winner."];
  "claim:SCI-E4-TAPER-NEAR-RETENTION-01" [label="claim: With initial near-retention matched, faster taper tails correlate with lower harmful-far influence and higher finite-horizon held-out-context reward; no steady-state or universal winner is claimed."];
  "claim:SCI-E4-TAPER-NET-UTILITY-01" [label="hypothesis: Outside the locally informative region, expected negative-sample net utility is hypothesized to be generally non-increasing with policy-relative distance and may approach zero or become negative; no exponential decay law is assumed."];
  "claim:SCI-EXP-FAMILY-UNIFICATION-01" [label="claim: Gaussian and categorical branches are unified through the necessary exponential-family signed-moment structure."];
  "claim:SCI-FISHER-CORRECTION-01" [label="claim: Fixed off-policy signed-gradient stability must use exact updates or the signed field Jacobian, not expected-Fisher SPD alone."];
  "claim:SCI-GAUSSIAN-VARIANCE-CORRECTION-01" [label="claim: Far-field negative samples repel the mean and contract variance/support rather than expanding mean and variance together."];
  "claim:SCI-HOPPER-EXTERNAL-CLAIM-01" [label="claim: Historical Hopper evidence is an external mechanism validation, not a normalized-return method table."];
  "claim:SCI-HOPPER-ROLE-01" [label="claim: EXT-H/Hopper provides learned-critic external mechanism and method validation rather than controlled ground truth."];
  "claim:SCI-NEGATIVE-DUAL-ROLE-01" [label="claim: Controlled negative gradients can beat the positive-only ceiling while anomalous far-field negatives destabilize training."];
  "claim:SCI-REMOTENESS-CONTROL-01" [label="claim: The method narrative is remoteness control under a stability-generalization trade-off; hard filtering is only a limiting case."];
  "claim:SCI-REPULSIVE-CORE-01" [label="claim: The core mechanism is attraction from positive advantage and far-field-amplified repulsion from fixed off-policy negative samples."];
  "claim:SCI-UTILITY-INFLUENCE-MISMATCH-01" [label="hypothesis: Far-field risk arises when informational utility decays with distance while optimization influence grows or remains persistent."];
