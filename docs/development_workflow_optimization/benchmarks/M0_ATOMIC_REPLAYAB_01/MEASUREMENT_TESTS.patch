+def _object_case(tmp_path: Path, *, family: str = "e7", failure=None, count: int = 4) -> Path:
+    terminal = {None: "READY", "stale_head": "STALE", "validation_failure": "BLOCKED"}[failure]
+    files = []
+    for index in range(count):
+        content = f"{family}-{index}\n"
+        files.append(
+            {
+                "path": f"configs/{family}_m0_{index}.yaml",
+                "mode": "100644",
+                "content": content,
+                "sha256": replay.hashlib.sha256(content.encode()).hexdigest(),
+            }
+        )
+    packet = tmp_path / "packet.yaml"
+    packet.write_text(
+        json.dumps(
+            {
+                "schema_version": 1,
+                "case_id": f"{family.upper()}-M0-TEST",
+                "family": family,
+                "expected_terminal_state": terminal,
+                "failure": failure,
+                "files": files,
+            }
+        ),
+        encoding="utf-8",
+    )
+    return packet
+
+
+def test_git_object_pair_produces_equivalent_tree_with_fewer_actions(tmp_path: Path) -> None:
+    code, payload = replay.run_git_object_pair(
+        SimpleNamespace(case_packet=str(_object_case(tmp_path)), output_root=str(tmp_path / "out"))
+    )
+    assert code == 0 and payload["status"] == "PASS"
+    assert [item["arm"] for item in payload["runs"]] == ["A", "B", "B", "A"]
+    trees = {item["tree_sha"] for item in payload["runs"]}
+    assert len(trees) == 1
+    for item in payload["runs"]:
+        assert item["ref_after"] == item["commit_sha"]
+        if item["arm"] == "B":
+            assert item["parent_sha"] == item["base_sha"]
+        else:
+            assert item["parent_sha"] != item["base_sha"]
+    assert max(item["operator_action_count"] for item in payload["runs"] if item["arm"] == "B") < min(
+        item["operator_action_count"] for item in payload["runs"] if item["arm"] == "A"
+    )
+
+
+@pytest.mark.parametrize(
+    ("failure", "terminal"),
+    [("stale_head", "STALE"), ("validation_failure", "BLOCKED")],
+)
+def test_git_object_failure_boundaries_preserve_expected_ref(
+    tmp_path: Path, failure: str, terminal: str
+) -> None:
+    packet = _object_case(tmp_path, family="e8", failure=failure)
+    code, payload = replay.run_git_object_pair(
+        SimpleNamespace(case_packet=str(packet), output_root=str(tmp_path / "out"))
+    )
+    assert code == 0
+    for item in payload["runs"]:
+        assert item["terminal_state"] == terminal
+        assert item["ref_after"] == (item["base_sha"] if failure == "stale_head" else None)
+
+
+def test_git_object_packet_rejects_protected_path_before_output(tmp_path: Path) -> None:
+    packet = _object_case(tmp_path)
+    payload = json.loads(packet.read_text(encoding="utf-8"))
+    payload["files"][0]["path"] = "docs/handoff.md"
+    packet.write_text(json.dumps(payload), encoding="utf-8")
+    with pytest.raises(ValueError, match="path, content, or hash"):
+        replay._object_packet(packet)
 
 
